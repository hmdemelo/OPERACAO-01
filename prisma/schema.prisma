generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(uuid())
  name            String
  email           String            @unique
  passwordHash    String
  role            Role              @default(STUDENT)
  phone           String?
  cpf             String?
  birthDate       DateTime?
  targetExam      String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  active          Boolean           @default(true)
  addressCity     String?
  addressState    String?
  dailyHours      Int?
  educationLevel  String?
  mentorLinks     MentorshipLink[]  @relation("MentorLinks")
  studentLink     MentorshipLink?   @relation("StudentLinks")
  logs            StudyLog[]
  authoredHistory StudyLogHistory[] @relation("HistoryAuthor")
  userConcursos   UserConcurso[]
  userSubjects    UserSubject[]
  weeklyPlans     WeeklyPlan[]
}

model MentorshipLink {
  id        String   @id @default(cuid())
  mentorId  String
  studentId String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  mentor    User     @relation("MentorLinks", fields: [mentorId], references: [id], onDelete: Cascade)
  student   User     @relation("StudentLinks", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([studentId])
}

model StudyLog {
  id                String            @id @default(cuid())
  userId            String
  date              DateTime
  hoursStudied      Float
  questionsAnswered Int
  correctAnswers    Int
  topic             String?
  createdAt         DateTime          @default(now())
  contentId         String?
  subjectId         String
  content           Content?          @relation(fields: [contentId], references: [id], onDelete: Cascade)
  subject           Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  history           StudyLogHistory[]
  weeklyPlanItem    WeeklyPlanItem?

  @@index([userId])
  @@index([date])
}

model Subject {
  id          String           @id @default(cuid())
  name        String
  createdAt   DateTime         @default(now())
  active      Boolean          @default(true)
  description String?          @db.VarChar(2048)
  contents    Content[]
  studyLogs   StudyLog[]
  users       UserSubject[]
  planItems   WeeklyPlanItem[]
}

model Content {
  id          String     @id @default(cuid())
  name        String
  subjectId   String
  createdAt   DateTime   @default(now())
  description String?    @db.VarChar(2048)
  subject     Subject    @relation(fields: [subjectId], references: [id])
  studyLogs   StudyLog[]

  @@index([subjectId])
}

model UserSubject {
  id        String  @id @default(cuid())
  userId    String
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
}

model UserConcurso {
  id         String   @id @default(cuid())
  userId     String
  concursoId String
  concurso   Concurso @relation(fields: [concursoId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, concursoId])
}

model Concurso {
  id          String         @id @default(cuid())
  name        String
  description String?        @db.VarChar(2048)
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  users       UserConcurso[]
}

model StudyLogHistory {
  id             String   @id @default(cuid())
  studyLogId     String
  previousValues Json
  newValues      Json
  changedById    String
  changedAt      DateTime @default(now())
  changedBy      User     @relation("HistoryAuthor", fields: [changedById], references: [id])
  studyLog       StudyLog @relation(fields: [studyLogId], references: [id], onDelete: Cascade)

  @@index([studyLogId])
  @@index([changedById])
}

model FeaturedStudent {
  id        String   @id @default(cuid())
  name      String
  role      String
  imageUrl  String
  quote     String
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Plan {
  id              String   @id @default(cuid())
  title           String
  description     String?
  price           Float
  oldPrice        Float?
  installments    String?
  features        String[]
  whatsappMessage String?
  highlighted     Boolean  @default(false)
  active          Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MethodItem {
  id          String   @id @default(cuid())
  step        String
  title       String
  description String
  icon        String
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WeeklyPlan {
  id        String           @id @default(cuid())
  userId    String
  startDate DateTime
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WeeklyPlanItem[]

  @@unique([userId, startDate])
  @@index([userId])
}

model WeeklyPlanItem {
  id              String     @id @default(cuid())
  planId          String
  dayOfWeek       Int
  blockIndex      Int
  subjectId       String?
  content         String?
  durationMinutes Int?
  notes           String?
  questionsDone   Int?
  correctCount    Int?
  completed       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  studyLogId      String?    @unique
  plan            WeeklyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  studyLog        StudyLog?  @relation(fields: [studyLogId], references: [id])
  subject         Subject?   @relation(fields: [subjectId], references: [id])

  @@index([planId])
  @@index([subjectId])
}

enum Role {
  ADMIN
  STUDENT
  MENTOR
}

model SystemSettings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
